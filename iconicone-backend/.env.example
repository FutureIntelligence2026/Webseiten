# ─── Admin Login ───────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=sicheres-passwort-hier

# ─── JWT Signierung ────────────────────────────────────
# Mindestens 32 zufällige Zeichen — z.B. mit: openssl rand -base64 32
JWT_SECRET=dein-geheimer-zufaelliger-schluessel-min-32-zeichen

# ─── Admin-Benachrichtigungen ──────────────────────────
# Wohin gehen die Benachrichtigungen wenn eine neue Anfrage kommt?
NOTIFY_EMAIL=deine@email.de

# ─── Firmenname ────────────────────────────────────────
FIRM_NAME=ICONICONE

# ─── CORS ──────────────────────────────────────────────
# Domain deiner Website (mehrere mit Komma trennen)
ALLOWED_ORIGINS=https://iconicone.vercel.app

# ─── Vercel KV (automatisch gesetzt) ──────────────────
# Diese werden automatisch gesetzt wenn du KV mit dem Projekt verbindest
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
